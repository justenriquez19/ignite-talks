---
import BaseLayout from './BaseLayout.astro';
import Navbar from '../components/ui/Navbar.astro';

interface Props {
  title: string;
  description?: string;
  slug: string;
  slideCount: number;
}

const { title, description, slug, slideCount } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <div class="talk-layout" data-slug={slug} data-slide-count={slideCount}>
    <Navbar showBackLink={true} talkTitle={title} />

    <!-- Progress bar -->
    <div class="progress-bar-container" id="progress-bar-container" aria-hidden="true">
      <div class="progress-bar-fill" id="progress-bar-fill"></div>
    </div>

    <!-- Main content -->
    <main class="talk-main" id="talk-main">
      <slot />
    </main>

    <!-- Slide counter -->
    <div class="slide-counter" id="slide-counter" aria-live="polite">
      <span class="slide-counter-current" id="slide-current">01</span>
      <span class="slide-counter-separator">/</span>
      <span class="slide-counter-total" id="slide-total">{String(slideCount).padStart(2, '0')}</span>
    </div>
  </div>
</BaseLayout>

<style>
  .talk-layout {
    position: relative;
    width: 100vw;
    height: 100vh;
    overflow: hidden;
    background-color: var(--color-ignite-black);
  }

  .progress-bar-container {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 3px;
    background-color: var(--color-ignite-surface);
    z-index: 100;
  }

  .progress-bar-fill {
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, var(--color-ignite-fire), var(--color-ignite-ember));
    transition: width var(--duration-default) var(--ease-default);
    transform-origin: left;
  }

  .talk-main {
    width: 100%;
    height: 100%;
  }

  .slide-counter {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--color-ignite-text-muted);
    z-index: 50;
    user-select: none;
    letter-spacing: 0.05em;
  }

  .slide-counter-current {
    color: var(--color-ignite-text-primary);
    font-weight: 600;
  }

  .slide-counter-separator {
    margin: 0 0.25rem;
    color: var(--color-ignite-border);
  }

  @media (max-width: 768px) {
    .slide-counter {
      bottom: 1rem;
      right: 1rem;
      font-size: 0.75rem;
    }
  }
</style>
