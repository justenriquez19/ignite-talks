---
import Icon from "./Icon.astro";

interface Props {
  showBackLink?: boolean;
  talkTitle?: string;
}

const { showBackLink = false, talkTitle } = Astro.props;
const pathname = Astro.url.pathname;
const isIndex = pathname === '/' || pathname === '/index.html' || pathname === '';
---

<nav class="navbar" id="navbar" role="navigation" aria-label="Navegación principal">
  <div class="navbar-inner">
    <a href="/" class="navbar-logo" aria-label="Volver a inicio — IGNITE TALKS">
      <svg class="navbar-flame" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M16 2C14.5 7 11 10 9 13c-2.5 3.8-3 7.5-1.5 11C9 27 12.5 30 16 30c3.5 0 7-3 8.5-6 1.5-3.5 1-7.2-1.5-11-2-3-5.5-6-7-11z" fill="url(#nav-flame)"/>
        <path d="M16 12c-1 3-2.5 5-3.5 7-1.2 2.3-0.8 4.5 0.5 6 1 1.2 2 2 3 2s2-0.8 3-2c1.3-1.5 1.7-3.7 0.5-6-1-2-2.5-4-3.5-7z" fill="url(#nav-inner)"/>
        <defs>
          <linearGradient id="nav-flame" x1="16" y1="2" x2="16" y2="30" gradientUnits="userSpaceOnUse">
            <stop stop-color="#ff4a33"/>
            <stop offset="0.5" stop-color="#e63620"/>
            <stop offset="1" stop-color="#ff6b35"/>
          </linearGradient>
          <linearGradient id="nav-inner" x1="16" y1="12" x2="16" y2="27" gradientUnits="userSpaceOnUse">
            <stop stop-color="#ff6b35"/>
            <stop offset="1" stop-color="#ffb347"/>
          </linearGradient>
        </defs>
      </svg>
      <span class="navbar-wordmark">IGNITE<span class="navbar-wordmark-talks">TALKS</span></span>
    </a>

    {isIndex && (
      <div class="navbar-actions">
        <a href="/justme" class="nav-connect-link" aria-label="Sobre Justo Enríquez">
          <span class="nav-connect-link-icon"><Icon name="user" size={16} /></span>
          <span class="nav-connect-link-label">Sobre mí</span>
        </a>
        <a href="https://github.com/justenriquez19" target="_blank" rel="noopener noreferrer" class="nav-connect-link" aria-label="GitHub">
          <span class="nav-connect-link-icon"><Icon name="github" size={16} /></span>
          <span class="nav-connect-link-label">GitHub</span>
        </a>
        <a href="https://www.linkedin.com/in/justo-enriquez/" target="_blank" rel="noopener noreferrer" class="nav-connect-link" aria-label="LinkedIn">
          <span class="nav-connect-link-icon"><Icon name="linkedin" size={16} /></span>
          <span class="nav-connect-link-label">LinkedIn</span>
        </a>
      </div>
    )}

    {showBackLink && talkTitle && (
      <span class="navbar-talk-title">{talkTitle}</span>
    )}
  </div>
</nav>

<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    padding: 1rem 1.5rem;
    z-index: 90;
    background: linear-gradient(180deg, var(--color-ignite-black) 0%, transparent 100%);
  }

  .navbar-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: var(--max-width-content);
    margin: 0 auto;
  }

  .navbar-logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    transition: opacity var(--duration-fast) var(--ease-default);
  }

  .navbar-logo:hover {
    opacity: 0.8;
  }

  .navbar-flame {
    width: 24px;
    height: 24px;
  }

  .navbar-wordmark {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-ignite-text-primary);
    letter-spacing: 0.08em;
  }

  .navbar-wordmark-talks {
    font-weight: 400;
    color: var(--color-ignite-text-secondary);
    margin-left: 0.25em;
  }

  .navbar-talk-title {
    font-family: var(--font-body);
    font-size: 1rem;
    color: #ffffff;
    max-width: 400px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .navbar-actions {
    display: flex;
    gap: 0.75rem;
    align-items: center;
  }

  .nav-connect-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background-color: var(--color-ignite-surface);
    border: 1px solid var(--color-ignite-border);
    border-radius: var(--radius-card);
    text-decoration: none;
    transition:
      border-color var(--duration-default) var(--ease-default),
      box-shadow var(--duration-default) var(--ease-default),
      transform var(--duration-default) var(--ease-default);
  }

  .nav-connect-link:hover {
    border-color: var(--color-ignite-fire);
    box-shadow: var(--shadow-glow);
    transform: translateY(-2px);
  }

  .nav-connect-link-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-ignite-fire-bright);
  }

  .nav-connect-link-label {
    font-size: 0.875rem;
    color: var(--color-ignite-text-primary);
    font-weight: 500;
  }

  @media (max-width: 768px) {
    .navbar {
      padding: 0.75rem 1rem;
    }

    .navbar-talk-title {
      display: none;
    }

    .navbar-flame {
      width: 20px;
      height: 20px;
    }

    .navbar-wordmark {
      font-size: 1rem;
    }

    .nav-connect-link-label {
      display: none;
    }

    .nav-connect-link {
      padding: 0.5rem;
    }

    .navbar-actions {
      gap: 0.5rem;
    }
  }
</style>
