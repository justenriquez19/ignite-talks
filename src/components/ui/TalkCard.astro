---
import type { CollectionEntry } from 'astro:content';

interface Props {
  talk: CollectionEntry<'talks'>;
}

const { talk } = Astro.props;
const { title, event, date, location, tags, slug, hero } = talk.data;

const formattedDate = new Date(date).toLocaleDateString('es-MX', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// Generate gradient based on hero value or fallback
const gradientMap: Record<string, string> = {
  'gradient-fire': 'linear-gradient(135deg, #e63620 0%, #ff6b35 50%, #ff4a33 100%)',
  'gradient-ember': 'linear-gradient(135deg, #ff6b35 0%, #e63620 100%)',
  'gradient-obsidian': 'linear-gradient(135deg, #1a1a1f 0%, #2a2a30 50%, #111114 100%)',
};

const cardGradient = gradientMap[hero ?? 'gradient-fire'] ?? gradientMap['gradient-fire'];
---

<a href={`/talks/${slug}`} class="talk-card" id={`talk-card-${slug}`} aria-label={`Ver presentación: ${title}`}>
  <div class="talk-card-hero" style={`background: ${cardGradient};`}>
    <div class="talk-card-hero-overlay"></div>
  </div>

  <div class="talk-card-body">
    <div class="talk-card-meta">
      <span class="talk-card-event">{event}</span>
      <span class="talk-card-dot" aria-hidden="true">·</span>
      <time class="talk-card-date" datetime={date.toISOString()}>
        {formattedDate}
      </time>
    </div>

    <h3 class="talk-card-title">{title}</h3>

    <p class="talk-card-location">{location}</p>

    <div class="talk-card-tags">
      {tags.map((tag) => (
        <span class="talk-card-tag">{tag}</span>
      ))}
    </div>
  </div>
</a>

<style>
  .talk-card {
    display: block;
    background-color: var(--color-ignite-surface);
    border: 1px solid var(--color-ignite-border);
    border-radius: var(--radius-card);
    overflow: hidden;
    text-decoration: none;
    transition:
      transform var(--duration-default) var(--ease-default),
      box-shadow var(--duration-default) var(--ease-default),
      border-color var(--duration-default) var(--ease-default);
  }

  .talk-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-glow);
    border-color: var(--color-ignite-fire);
  }

  .talk-card:hover .talk-card-hero-overlay {
    opacity: 0;
  }

  .talk-card-hero {
    position: relative;
    height: 160px;
    overflow: hidden;
  }

  .talk-card-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      transparent 50%,
      var(--color-ignite-surface) 100%
    );
    transition: opacity var(--duration-default) var(--ease-default);
  }

  .talk-card-body {
    padding: 1.25rem 1.5rem 1.5rem;
  }

  .talk-card-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
    font-size: 0.75rem;
    color: var(--color-ignite-text-muted);
    font-family: var(--font-mono);
  }

  .talk-card-dot {
    color: var(--color-ignite-border);
  }

  .talk-card-title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-ignite-text-primary);
    line-height: 1.3;
    margin-bottom: 0.5rem;
  }

  .talk-card-location {
    font-size: 0.875rem;
    color: var(--color-ignite-text-secondary);
    margin-bottom: 1rem;
  }

  .talk-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .talk-card-tag {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    padding: 0.25rem 0.625rem;
    background-color: var(--color-ignite-surface-raised);
    color: var(--color-ignite-text-muted);
    border-radius: var(--radius-full);
    border: 1px solid var(--color-ignite-border);
    letter-spacing: 0.02em;
  }

  .talk-card:hover .talk-card-tag {
    border-color: var(--color-ignite-glow-strong);
  }
</style>
