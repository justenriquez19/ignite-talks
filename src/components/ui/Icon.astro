---
/**
 * Icon.astro — Inline SVG icon component with brand colors.
 *
 * Usage:
 *   <Icon name="fire" />
 *   <Icon name="fire" size={20} />
 *   <Icon name="map-pin" size={16} class="my-icon" />
 *
 * All icons use Ignite Talks brand colors via gradients/fills
 * so they look premium and colorful — no generic monochrome icons.
 */

interface Props {
  name: 'fire' | 'map-pin' | 'flag-mx' | 'peace' | 'lightning' | 'linkedin' | 'github';
  size?: number;
  class?: string;
}

const { name, size = 20, class: className } = Astro.props;

// Unique ID per instance to avoid SVG gradient/clipPath collisions
const uid = Math.random().toString(36).slice(2, 8);
---

<span
  class:list={['icon', className]}
  style={`--icon-size: ${size}px;`}
  aria-hidden="true"
  role="img"
>
  {name === 'fire' && (
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      width={size}
      height={size}
      fill="none"
    >
      <defs>
        <linearGradient id={`fire-grad-${uid}`} x1="0" y1="1" x2="0" y2="0">
          <stop offset="0%" stop-color="#e63620" />
          <stop offset="50%" stop-color="#ff6b35" />
          <stop offset="100%" stop-color="#ffb347" />
        </linearGradient>
        <linearGradient id={`fire-core-${uid}`} x1="0" y1="1" x2="0" y2="0">
          <stop offset="0%" stop-color="#ff4a33" />
          <stop offset="100%" stop-color="#ffe066" />
        </linearGradient>
      </defs>
      <!-- Outer flame -->
      <path
        d="M12 2C12 2 5 9.5 5 14.5C5 18.64 8.13 22 12 22C15.87 22 19 18.64 19 14.5C19 9.5 12 2 12 2Z"
        fill={`url(#fire-grad-${uid})`}
      />
      <!-- Inner glow -->
      <path
        d="M12 9C12 9 8.5 13 8.5 15.5C8.5 17.43 10.07 19 12 19C13.93 19 15.5 17.43 15.5 15.5C15.5 13 12 9 12 9Z"
        fill={`url(#fire-core-${uid})`}
        opacity="0.9"
      />
    </svg>
  )}

  {name === 'map-pin' && (
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      width={size}
      height={size}
      fill="none"
    >
      <defs>
        <linearGradient id={`pin-grad-${uid}`} x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%" stop-color="#ff4a33" />
          <stop offset="100%" stop-color="#e63620" />
        </linearGradient>
      </defs>
      <!-- Pin body -->
      <path
        d="M12 2C8.13 2 5 5.13 5 9C5 13.25 9.95 19.47 11.4 21.21C11.7 21.58 12.3 21.58 12.6 21.21C14.05 19.47 19 13.25 19 9C19 5.13 15.87 2 12 2Z"
        fill={`url(#pin-grad-${uid})`}
      />
      <!-- Inner circle -->
      <circle cx="12" cy="9" r="3" fill="#08080a" opacity="0.85" />
      <!-- Bright dot center -->
      <circle cx="12" cy="9" r="1.2" fill="#ffb347" />
    </svg>
  )}

  {name === 'flag-mx' && (
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 18"
      width={Math.round(size * 1.33)}
      height={size}
      fill="none"
    >
      <defs>
        <clipPath id={`flag-clip-${uid}`}>
          <rect width="24" height="18" rx="3" />
        </clipPath>
      </defs>
      <g clip-path={`url(#flag-clip-${uid})`}>
        <!-- Green stripe -->
        <rect x="0" y="0" width="8" height="18" fill="#006847" />
        <!-- White stripe -->
        <rect x="8" y="0" width="8" height="18" fill="#f0ece6" />
        <!-- Red stripe -->
        <rect x="16" y="0" width="8" height="18" fill="#ce1126" />
        <!-- Emblem hint: small circle in center -->
        <circle cx="12" cy="9" r="2.2" fill="#006847" opacity="0.35" />
        <circle cx="12" cy="9" r="1" fill="#8b6914" opacity="0.6" />
      </g>
      <!-- Subtle border -->
      <rect
        width="24"
        height="18"
        rx="3"
        fill="none"
        stroke="#2a2a30"
        stroke-width="0.75"
      />
    </svg>
  )}

  {name === 'peace' && (
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      width={size}
      height={size}
      fill="none"
    >
      <defs>
        <linearGradient id={`peace-grad-${uid}`} x1="0" y1="1" x2="1" y2="0">
          <stop offset="0%" stop-color="#e63620" />
          <stop offset="100%" stop-color="#ff6b35" />
        </linearGradient>
      </defs>
      <!-- Hand: index + middle up, ring + pinky curled, thumb across -->
      <!-- Palm base -->
      <path
        d="M8.5 13V19.5C8.5 20.33 9.17 21 10 21H14.5C16.43 21 18 19.43 18 17.5V13"
        stroke={`url(#peace-grad-${uid})`}
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        fill="none"
      />
      <!-- Index finger -->
      <path
        d="M10 13V4.5C10 3.67 10.67 3 11.5 3C12.33 3 13 3.67 13 4.5V12"
        stroke={`url(#peace-grad-${uid})`}
        stroke-width="1.5"
        stroke-linecap="round"
        fill="none"
      />
      <!-- Middle finger -->
      <path
        d="M14 12V5.5C14 4.67 14.67 4 15.5 4C16.33 4 17 4.67 17 5.5V12"
        stroke={`url(#peace-grad-${uid})`}
        stroke-width="1.5"
        stroke-linecap="round"
        fill="none"
      />
      <!-- Thumb -->
      <path
        d="M10 14H7.5C6.67 14 6 13.33 6 12.5C6 11.67 6.67 11 7.5 11H8.5"
        stroke={`url(#peace-grad-${uid})`}
        stroke-width="1.5"
        stroke-linecap="round"
        fill="none"
      />
    </svg>
  )}

  {name === 'lightning' && (
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      width={size}
      height={size}
      fill="none"
    >
      <defs>
        <linearGradient id={`bolt-grad-${uid}`} x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%" stop-color="#ffb347" />
          <stop offset="50%" stop-color="#ff6b35" />
          <stop offset="100%" stop-color="#e63620" />
        </linearGradient>
      </defs>
      <path
        d="M13 2L4.5 13H12L11 22L19.5 11H12L13 2Z"
        fill={`url(#bolt-grad-${uid})`}
      />
    </svg>
  )}

  {name === 'linkedin' && (
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      width={size}
      height={size}
      fill="none"
    >
      <!-- LinkedIn "in" logo — official brand color -->
      <path
        d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
        fill="#0A66C2"
      />
    </svg>
  )}

  {name === 'github' && (
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      width={size}
      height={size}
      fill="none"
    >
      <!-- GitHub octocat logo -->
      <path
        d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"
        fill="#f0ece6"
      />
    </svg>
  )}
</span>

<style>
  .icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: var(--icon-size);
    height: var(--icon-size);
    flex-shrink: 0;
    vertical-align: middle;
    line-height: 1;
  }

  .icon svg {
    display: block;
  }
</style>
